{
  "name": "custom-better-auth",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.32.0",
      "better-auth": "1.4.9",
      "@convex-dev/better-auth": "^0.10.11",
      "alchemy": "^0.82.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @custom-better-auth/backend dev",
    "dev:setup": "turbo -F @custom-better-auth/backend dev:setup",
    "deploy": "turbo -F @custom-better-auth/infra deploy",
    "destroy": "turbo -F @custom-better-auth/infra destroy",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@custom-better-auth/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@custom-better-auth/config": "workspace:*",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.2.23"
}
